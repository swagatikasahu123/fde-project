# Copy this to .env and fill in your values

PORT=4000
DB_PATH=./sap_o2c.db
DATA_DIR=./data
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─────────────────────────────────────────────────────────
# LLM API KEY — pick ONE free provider and set its key
# ─────────────────────────────────────────────────────────

# OPTION 1: Google Gemini (RECOMMENDED — most generous free tier)
# Get key: https://ai.google.dev  → "Get API key" → Create API key
# Free limits: 15 RPM, 1 million tokens/day — plenty for this project
GEMINI_API_KEY=your-gemini-api-key-here

# OPTION 2: Groq (fastest inference, very generous free tier)
# Get key: https://console.groq.com → API Keys → Create
# Model used: llama-3.3-70b-versatile (or mixtral-8x7b-32768)
# GROQ_API_KEY=your-groq-api-key-here

# OPTION 3: OpenRouter (access to many models, has free tier)
# Get key: https://openrouter.ai → Keys
# OPENROUTER_API_KEY=your-openrouter-api-key-here
